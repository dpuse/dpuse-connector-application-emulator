{
    "name": "@datapos/datapos-connector-data-application-emulator",
    "license": "ISC",
    "private": "true",
    "version": "0.1.336",
    "dependencies": {
        "@datapos/datapos-share-core": "^0.1.402",
        "csv-parse": "^5.3.1"
    },
    "devDependencies": {
        "@datapos/datapos-operations": "^0.1.300",
        "@typescript-eslint/eslint-plugin": "^6.7.0",
        "@typescript-eslint/parser": "^6.7.0",
        "eslint": "^8.49.0",
        "eslint-plugin-import": "^2.28.1",
        "prettier": "^3.0.3",
        "typescript": "^5.2.2",
        "vite": "^4.4.9",
        "vite-plugin-dts": "^3.5.3"
    },
    "scripts": {
        "audit": "npm audit",
        "build": "npx vite build",
        "bumpVersion": "node -e \"require('@datapos/datapos-operations/scriptHelpers').bumpVersion()\"",
        "check": "npm outdated",
        "document": "npx npm-license-crawler --onlyDirectDependencies --production --relativeLicensePath --json LICENSES.json",
        "format": "echo \"***** FORMAT SCRIPT NOT IMPLEMENTED. *****\"",
        "lint": "npx eslint **/*.ts",
        "publishToNPM": "echo \"***** PUBLISH TO NPM SCRIPT NOT IMPLEMENTED. *****\"",
        "release": "npm run syncWithGitHub && npm run build && npm run uploadConnector",
        "syncWithGitHub": "npm run bumpVersion && node -e \"require('@datapos/datapos-operations/scriptHelpers').syncWithGitHub()\"",
        "test": "echo \"***** TEST SCRIPT NOT IMPLEMENTED. *****\"",
        "updateDependencies": "npm run updateOperations && npm run updateShareCore",
        "updateOperations": "npm install --save-dev @datapos/datapos-operations@latest",
        "updateShareCore": "npm install @datapos/datapos-share-core@latest",
        "uploadConnector": "node -e \"require('@datapos/datapos-operations/scriptHelpers').uploadConnector()\""
    }
}